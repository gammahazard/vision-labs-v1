# Reolink Camera
CAMERA_IP=192.168.2.10
CAMERA_USER=admin
CAMERA_PASSWORD=YOUR_CAMERA_PASSWORD
RTSP_MAIN=rtsp://admin:${CAMERA_PASSWORD}@${CAMERA_IP}:554/h264Preview_01_main
RTSP_SUB=rtsp://admin:${CAMERA_PASSWORD}@${CAMERA_IP}:554/h264Preview_01_sub

# Telegram Bot (Phase 6 — Notifications)
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN
TELEGRAM_CHAT_ID=YOUR_CHAT_ID
# Comma-separated Telegram user IDs allowed to send bot commands
# Find your ID: send /start to @userinfobot on Telegram
TELEGRAM_ALLOWED_USERS=YOUR_USER_ID

# OpenWeatherMap (optional — conditions panel)
OPENWEATHER_API_KEY=YOUR_API_KEY

# Camera location — used for sunrise/sunset calculations (astral)
LOCATION_NAME=My City
LOCATION_REGION=State/Province
LOCATION_TIMEZONE=America/Toronto
LOCATION_LAT=55
LOCATION_LON=55

# QNAP NAS (CIFS/SMB volumes for DVR, events, snapshots, Telegram audit)
QNAP_IP=192.168.1.250
QNAP_USER=admin
QNAP_PASSWORD=YOUR_QNAP_PASSWORD
